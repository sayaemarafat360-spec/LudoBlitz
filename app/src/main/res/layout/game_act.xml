<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="16dp">

    <TextView android:id="@+id/tvPlayer" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#FFF" android:textSize="20sp" app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>

    <View android:id="@+id/viewColor" android:layout_width="20dp" android:layout_height="20dp"
        android:layout_marginEnd="8dp" app:layout_constraintEnd_toStartOf="@id/tvPlayer"
        app:layout_constraintTop_toTopOf="@id/tvPlayer" app:layout_constraintBottom_toBottomOf="@id/tvPlayer"/>

    <TextView android:id="@+id/tvDice" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="-" android:textColor="#FFF" android:textSize="48sp" android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvPlayer" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="32dp"/>

    <TextView android:id="@+id/tvMoves" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="" android:textColor="#FFD700" android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvDice" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="16dp"/>

    <TextView android:id="@+id/tvWin" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="" android:textColor="#0F0" android:textSize="28sp" android:textStyle="bold"
        android:visibility="gone" app:layout_constraintTop_toBottomOf="@id/tvMoves"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <Button android:id="@+id/btnRoll" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Roll Dice" app:layout_constraintTop_toBottomOf="@id/tvWin"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <Button android:id="@+id/btnExit" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Exit" app:layout_constraintTop_toBottomOf="@id/btnRoll"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
